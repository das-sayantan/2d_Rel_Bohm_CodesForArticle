            RowBox[{"xL", "<", "xmin"}], "||", 
            RowBox[{"xL", ">", "xmax"}], "||", 
            RowBox[{"xR", "<", "xmin"}], "||", 
            RowBox[{"xR", ">", "xmax"}]}], ",", 
           RowBox[{"Break", "[", "]"}]}], "]"}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Take", "[", 
       RowBox[{"data", ",", "k"}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"--", 
     RowBox[{"-", " ", 
      RowBox[{"trajectories", " ", "--"}]}]}], "-"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Creating", " ", "data"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ProbtAll", "=", 
    RowBox[{"ParallelTable", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", "y", ",", 
        RowBox[{"(", 
         RowBox[{"prob", "/.", " ", 
          RowBox[{"t", "->", 
           RowBox[{"(", 
            RowBox[{"y", "/", "vyConst"}], ")"}]}]}], ")"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "xmin", ",", "xmax", ",", "xinc"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "ymin", ",", "ymax", ",", "yinc"}], "}"}]}], "]"}]}],
    ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"allData", "=", 
    RowBox[{"ParallelTable", "[", 
     RowBox[{
      RowBox[{"GenTraj", "[", 
       RowBox[{
        RowBox[{"startLeft", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
        RowBox[{"startRight", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
        RowBox[{"startLeft", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "2"}], "]"}], "]"}], ",", 
        RowBox[{"tStartsSeed", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "nTrajSide"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"trajLines", "=", 
    RowBox[{"Join", "@@", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Line", "[", 
          RowBox[{"allData", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", 
             RowBox[{"1", ";;", " ", ";;", "2"}], ",", "1"}], "]"}], "]"}], 
          "]"}], ",", 
         RowBox[{"Line", "[", 
          RowBox[{"allData", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", 
             RowBox[{"2", ";;", " ", ";;", "2"}], ",", "1"}], "]"}], "]"}], 
          "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "allData", "]"}]}], "}"}]}], "]"}]}]}], ";"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", "Plotting", "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"densityPlot", "=", 
    RowBox[{"ListDensityPlot", "[", 
     RowBox[{
      RowBox[{"ArrayFlatten", "[", 
       RowBox[{"ProbtAll", ",", "1"}], "]"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"PlotLegends", "->", 
       RowBox[{"BarLegend", "[", 
        RowBox[{"Automatic", ",", 
         RowBox[{"LabelStyle", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"FontSize", "->", "30"}], ",", 
            RowBox[{"FontFamily", "->", "\"\<Times New Roman\>\""}]}], 
           "}"}]}]}], "]"}]}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
      RowBox[{"LabelStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"FontSize", "->", "30"}], ",", 
         RowBox[{"FontFamily", "->", "\"\<Times New Roman\>\""}], ",", 
         "Black"}], "}"}]}], ",", 
      RowBox[{"ImageSize", "->", "600"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"trajPlot", "=", 
    RowBox[{"Graphics", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Directive", "[", 
         RowBox[{"White", ",", 
          RowBox[{"Opacity", "[", "0.75", "]"}], ",", 
          RowBox[{"Thickness", "[", "0.002", "]"}], ",", 
          RowBox[{"CapForm", "[", "\"\<Round\>\"", "]"}], ",", 
          RowBox[{"JoinForm", "[", "\"\<Round\>\"", "]"}]}], "]"}], ",", 
        "trajLines"}], "}"}], ",", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"xmin", ",", "xmax"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"ymin", ",", "ymax"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"ImageSize", "->", "600"}], ",", 
      RowBox[{"Background", "->", "None"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ShowPlot", "=", 
   RowBox[{"Show", "[", 
