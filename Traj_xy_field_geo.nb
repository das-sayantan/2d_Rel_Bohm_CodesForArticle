            RowBox[{"xR", ">", "xmax"}]}], ",", 
           RowBox[{"Break", "[", "]"}]}], "]"}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Take", "[", 
       RowBox[{"data", ",", "k"}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
