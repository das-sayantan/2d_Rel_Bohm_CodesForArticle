            RowBox[{"{", 
             RowBox[{"vxL", ",", "vyConst"}], "}"}]}], "}"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"k", "++"}], ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"data", "[", 
