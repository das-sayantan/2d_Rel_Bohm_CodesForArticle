       RowBox[{"ConstantArray", "[", 
        RowBox[{"None", ",", 
         RowBox[{"2", " ", "nmax"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"t", "<=", "tmax"}], "&&", 
         RowBox[{"ymin", "<=", "y", "<=", "ymax"}]}], ",", 
        RowBox[{
         RowBox[{"vxL", "=", 
          RowBox[{"vxFun", "[", 
           RowBox[{"xL", ",", "y", ",", "t"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"vxR", "=", 
          RowBox[{"vxFun", "[", 
           RowBox[{"xR", ",", "y", ",", "t"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"k", "++"}], ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"data", "[", 
           RowBox[{"[", "k", "]"}], "]"}], "=", 
