             RowBox[{"vxR", ",", "vyConst"}], "}"}]}], "}"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"xL", "=", 
          RowBox[{"xL", "+", 
           RowBox[{"tinc", " ", "vxL"}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"xR", "=", 
          RowBox[{"xR", "+", 
           RowBox[{"tinc", " ", "vxR"}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"y", "=", 
          RowBox[{"y", "+", 
           RowBox[{"tinc", " ", "vyConst"}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"t", "=", 
          RowBox[{"t", "+", "tinc"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"xL", "<", "xmin"}], "||", 
            RowBox[{"xL", ">", "xmax"}], "||", 
